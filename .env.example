# ============================================================
# Docker-Hadoop-Cluster Environment Variables
# Docker-Hadoop-Cluster 环境变量清单（教学版）
# ============================================================

# Image settings | 镜像设置
HADOOP_VERSION=3.4.1
IMAGE_NAME=hadoop-cluster
IMAGE_TAG=3.4.1
HADOOP_BASE_URL=https://repo.huaweicloud.com/apache/hadoop/common
HADOOP_FALLBACK_BASE_URLS=https://repo.huaweicloud.com/apache/hadoop/common https://dlcdn.apache.org/hadoop/common https://archive.apache.org/dist/hadoop/common
HADOOP_DOWNLOAD_RETRY=2
HADOOP_DOWNLOAD_RETRY_DELAY=2
HADOOP_DOWNLOAD_CONNECT_TIMEOUT=10
HADOOP_DOWNLOAD_MAX_TIME=0
HADOOP_DOWNLOAD_MIN_SPEED=1024
HADOOP_DOWNLOAD_MIN_SPEED_TIME=30
HADOOP_TARBALL_SHA512=09cda6943625bc8e4307deca7a4df76d676a51aca1b9a0171938b793521dfe1ab5970fdb9a490bab34c12a2230ffdaed2992bad16458169ac51b281be1ab6741
# Optional per-architecture checksums for CI/multi-arch publish
HADOOP_TARBALL_SHA512_AMD64=09cda6943625bc8e4307deca7a4df76d676a51aca1b9a0171938b793521dfe1ab5970fdb9a490bab34c12a2230ffdaed2992bad16458169ac51b281be1ab6741
HADOOP_TARBALL_SHA512_ARM64=09cda6943625bc8e4307deca7a4df76d676a51aca1b9a0171938b793521dfe1ab5970fdb9a490bab34c12a2230ffdaed2992bad16458169ac51b281be1ab6741
# Optional per-architecture archive names (leave empty to use hadoop-${HADOOP_VERSION}.tar.gz)
HADOOP_ARCHIVE_AMD64=
HADOOP_ARCHIVE_ARM64=
AWS_SDK_BUNDLE_VERSION=2.41.30

# Network settings | 网络设置
HADOOP_NETWORK_NAME=hadoop-net
HOST_BIND_IP=127.0.0.1

# Config template path in container | 容器内配置模板目录
HADOOP_CONF_TEMPLATE_DIR=/opt/hadoop-conf-template
SSH_SHARED_DIR=/shared-ssh

# Hostnames used by Hadoop configs | Hadoop 配置使用的主机名
NAMENODE_HOST=hadoop1
RESOURCEMANAGER_HOST=hadoop2
SECONDARY_NAMENODE_HOST=hadoop3
JOBHISTORY_HOST=hadoop3

# Exposed service ports | 暴露到宿主机的服务端口
NAMENODE_RPC_PORT=9000
NAMENODE_HTTP_PORT=9870
RESOURCEMANAGER_WEB_PORT=8088
SECONDARY_NAMENODE_HTTP_PORT=9868
JOBHISTORY_RPC_PORT=10020
JOBHISTORY_WEB_PORT=19888

# Core HDFS behavior | HDFS 核心行为参数
# Single replication for this 3-node dev/teaching cluster to avoid under-replication warnings
DFS_REPLICATION=1
AUTO_FORMAT_NAMENODE=true
HADOOP_PROXYUSER_ROOT_HOSTS=hadoop1,hadoop2,hadoop3,localhost
HADOOP_PROXYUSER_ROOT_GROUPS=root

# Runtime security toggles | 运行时安全开关
HADOOP_DAEMON_USER=hadoop
ENABLE_SSH_USER_ENV=false
AUTO_RESET_DATANODE_DATA_ON_VERSION_CHANGE=true

# JVM heap controls | JVM 堆内存控制（避免容器内 OOM 被动杀进程）
HADOOP_HEAPSIZE_MAX=1024
HADOOP_NAMENODE_OPTS="-Xms512m -Xmx1024m"
HADOOP_DATANODE_OPTS="-Xms256m -Xmx768m"
HADOOP_SECONDARYNAMENODE_OPTS="-Xms256m -Xmx512m"
YARN_RESOURCEMANAGER_OPTS="-Xms256m -Xmx768m"
YARN_NODEMANAGER_OPTS="-Xms256m -Xmx512m"
MAPRED_HISTORYSERVER_OPTS="-Xms256m -Xmx512m"

# Startup gate behavior | 启动闸门参数（非 NameNode 节点等待 NameNode）
WAIT_FOR_NAMENODE_RETRIES=60
WAIT_FOR_NAMENODE_INTERVAL=2

# Runtime data directories inside containers | 容器内运行数据目录
HADOOP_TMP_DIR=/hadoop/tmp
HDFS_NAMENODE_NAME_DIR=/hadoop/dfs/name
HDFS_DATANODE_DATA_DIR=/hadoop/dfs/data
YARN_NODEMANAGER_LOCAL_DIR=/hadoop/yarn/local
YARN_NODEMANAGER_LOG_DIR=/hadoop/yarn/logs
MAPRED_HISTORY_TMP_DIR=/hadoop/mr-history/tmp
MAPRED_HISTORY_DONE_DIR=/hadoop/mr-history/done

# Named volume names | 命名卷名称（默认避免 bind mount 跨平台 I/O 损耗）
SSH_KEYS_VOLUME_NAME=hadoop_ssh_keys
HADOOP1_NAME_VOLUME_NAME=hadoop1_name
HADOOP1_DATA_VOLUME_NAME=hadoop1_data
HADOOP1_TMP_VOLUME_NAME=hadoop1_tmp
HADOOP2_DATA_VOLUME_NAME=hadoop2_data
HADOOP2_YARN_LOCAL_VOLUME_NAME=hadoop2_yarn_local
HADOOP2_YARN_LOGS_VOLUME_NAME=hadoop2_yarn_logs
HADOOP2_TMP_VOLUME_NAME=hadoop2_tmp
HADOOP3_DATA_VOLUME_NAME=hadoop3_data
HADOOP3_TMP_VOLUME_NAME=hadoop3_tmp
HADOOP3_HISTORY_TMP_VOLUME_NAME=hadoop3_history_tmp
HADOOP3_HISTORY_DONE_VOLUME_NAME=hadoop3_history_done

# Docker healthcheck tuning | Docker 健康检查参数
HEALTHCHECK_INTERVAL=20s
HEALTHCHECK_TIMEOUT=8s
HEALTHCHECK_RETRIES=15
HEALTHCHECK_START_PERIOD=40s

# Optional secure profile values | 可选安全模板资源限制
SECURE_PIDS_LIMIT=512
SECURE_MEM_LIMIT=2g
SECURE_CPUS=1.5
