# ============================================================
# Editor files | 编辑器临时文件
# ============================================================
# EN: Local VS Code workspace metadata should not be versioned.
# CN: 本地 VS Code 工作区元信息不应进入版本控制。
.vscode/

# ============================================================
# Runtime logs | 运行日志
# ============================================================
# EN: Generic log files generated by containers, scripts, or debug sessions.
# CN: 容器、脚本或调试过程产生的通用日志文件。
*.log
logs/

# ============================================================
# Hadoop runtime data | Hadoop 运行期数据目录
# ============================================================
# EN: These directories contain mutable runtime data and binary fragments.
# CN: 这些目录保存可变运行数据与二进制碎片，不应提交到 Git。
/data/
/hadoop-data/
/tmp/

# ============================================================
# Common Hadoop generated paths | 常见 Hadoop 产物路径
# ============================================================
# EN: Safety net patterns in case data dirs are moved or renamed.
# CN: 兜底规则，防止未来调整目录后误提交运行产物。
**/dfs/name/
**/dfs/data/
**/yarn/local/
**/yarn/logs/
**/mr-history/
